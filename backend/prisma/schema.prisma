generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Product {
  id          Int      @id @default(autoincrement())

  title       String

  category    String

  description String

  image       String

  price       Float

  createdAt   DateTime @default(now())
}